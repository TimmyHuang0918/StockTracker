<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <appSettings>
        <add key="UseMockApi" value="true" />
        <add key="CapitalApiLoginUrl" value="https://api.example.com/capital/login" />
        <add key="CapitalApiSubscribeUrl" value="https://api.example.com/capital/subscribe" />
        <add key="CapitalApiQuoteUrl" value="https://api.example.com/capital/quote" />
    </appSettings>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
</configuration>