<Window x:Class="StockTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:viewmodels="clr-namespace:StockTracker.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:MainWindowViewModel}"
        mc:Ignorable="d"
        Title="股票監測主控台" Height="800" Width="1200" WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}" WindowStyle="None" ResizeMode="CanResizeWithGrip">
    <Grid Margin="12" Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="4" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
            <DockPanel LastChildFill="True" Margin="8,0">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Content="＿" Width="36" Height="24" Click="MinimizeButton_OnClick"/>
                    <Button Content="▢" Width="36" Height="24" Margin="6,0,0,0" Click="MaximizeRestoreButton_OnClick"/>
                    <Button Content="✕" Width="36" Height="24" Margin="6,0,0,0" Click="CloseButton_OnClick"/>
                </StackPanel>
                <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="股票監測主控台"/>
            </DockPanel>
        </Border>

        <DockPanel Grid.Row="1">
            <TextBlock Text="已訂閱股票" FontSize="20" FontWeight="SemiBold" DockPanel.Dock="Left" Margin="0,10,0,0"/>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <TextBlock Text="週期" FontSize="18" Margin="12" RenderTransformOrigin="-1.52,0.529" />
                <ComboBox Width="125" Height="30" Margin="10,5,10,5" ItemsSource="{Binding GlobalKLineIntervals}" SelectedItem="{Binding SelectedGlobalKLineInterval, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      SelectionChanged="comboBoxChangeInterval_SelectionChanged">
                    <ComboBox.Template>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <!-- 外框改成橢圓 -->
                                <Border CornerRadius="5" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                                    <DockPanel>
                                        <!-- 顯示選取文字 -->
                                        <ContentPresenter Margin="8,0,24,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>
                                        <!-- 下拉箭頭 -->
                                        <ToggleButton DockPanel.Dock="Right" Width="20" Margin="30,0,4,0"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Focusable="False"
                                                  ClickMode="Press"
                                                  Background="Transparent"
                                                  BorderThickness="0">
                                            <Path VerticalAlignment="Center" HorizontalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z" Fill="{TemplateBinding Foreground}"/>
                                        </ToggleButton>
                                    </DockPanel>
                                </Border>
                                <!-- 下拉清單 -->
                                <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                    <Border CornerRadius="10" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                                        <ScrollViewer>
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </ControlTemplate>
                    </ComboBox.Template>
                </ComboBox>
                <TextBlock Text="K棒數量" FontSize="18" Margin="12" RenderTransformOrigin="-1.52,0.529" />
                <ComboBox Width="100" Margin="0,10,10,10" Height="30" ItemsSource="{Binding GlobalKLineCount}" SelectedItem="{Binding SelectedGlobalKLineCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    SelectionChanged="comboBoxChangeInterval_SelectionChanged">
                    <ComboBox.Template>
                        <ControlTemplate TargetType="{x:Type ComboBox}">
                            <Grid>
                                <!-- 外框改成橢圓 -->
                                <Border CornerRadius="5" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                                    <DockPanel>
                                        <!-- 顯示選取文字 -->
                                        <ContentPresenter Margin="8,0,24,0"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left"
                                            Content="{TemplateBinding SelectionBoxItem}"
                                            ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                            ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>
                                        <ToggleButton DockPanel.Dock="Right" Width="20" Margin="20,0,4,0"
                                            IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource Mode=TemplatedParent}}"
                                            Focusable="False"
                                            ClickMode="Press"
                                            Background="Transparent"
                                            BorderThickness="0">
                                            <Path VerticalAlignment="Center" HorizontalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z" Fill="{TemplateBinding Foreground}"/>
                                        </ToggleButton>
                                    </DockPanel>
                                </Border>
                                <!-- 下拉清單 -->
                                <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                    <Border CornerRadius="10" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                                        <ScrollViewer>
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </ControlTemplate>
                    </ComboBox.Template>
                </ComboBox>

                <TextBox Width="120" Height="30" VerticalContentAlignment="Center" Name="textBoxSubscribe"
                         Text="{Binding NewSymbol, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock  Text="{Binding NewSymbolRelativeName}" Foreground="Gray" FontSize="18" Margin="12" RenderTransformOrigin="-1.52,0.529" />
                <Button Content="訂閱" Name="btnSubscribe" Width="80" Margin="8" Click="btnSubscribe_Click" />
                <Button Content="取消訂閱" Width="90" Margin="8" Click="btnUnsubscribe_Click"/>
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="3" BorderThickness="1" BorderBrush="{DynamicResource AppBorderBrush}" Background="{DynamicResource SurfaceBrush}" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="200"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="320" MinWidth="180" MaxWidth="600" x:Name="RankingColumn"/>
                </Grid.ColumnDefinitions>

                <!-- K線清單 -->
                <DockPanel Grid.Column="0">
                    <TextBlock Text="全部訂閱股票 K 線總覽（雙擊可開啟詳細圖表）" FontWeight="Bold" Margin="0,0,0,8" DockPanel.Dock="Top"/>
                <ListBox ItemsSource="{Binding Stocks}" BorderThickness="0" Background="{DynamicResource SurfaceBrush}" 
                         SelectionChanged="ListBox_SelectionStockChanged"
                         MouseDoubleClick="StockList_OnMouseDoubleClick"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.CanContentScroll="False">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Width" Value="430"/>
                            <Setter Property="Margin" Value="0,0,10,10"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8" BorderThickness="1" BorderBrush="{DynamicResource AppBorderBrush}" Background="{DynamicResource SurfaceAltBrush}">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,6">
                                        <Border DockPanel.Dock="Right" Padding="6,3" Margin="8,0,0,0"
                                                Background="#AA1E1E1E" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="4">
                                            <TextBlock FontSize="15" FontWeight="SemiBold" x:Name="PriceTextBlock">
                                                <Run Text="現價 " Foreground="{DynamicResource MutedForegroundBrush}"/>
                                                <Run Text="{Binding LatestPrice, StringFormat={}{0:F2}, Mode=OneWay, NotifyOnTargetUpdated=True}" Foreground="{Binding LatestChangeBrush}"/>
                                                <Run Text="  (" Foreground="{Binding LatestChangeBrush}"/>
                                                <Run Text="{Binding ChangePercentText, Mode=OneWay, NotifyOnTargetUpdated=True}" Foreground="{Binding LatestChangeBrush}"/>
                                                <Run Text=" )" Foreground="{Binding LatestChangeBrush}" />

                                                <TextBlock.Triggers>
                                                    <!-- 當 Binding 更新時觸發 -->
                                                    <EventTrigger RoutedEvent="Binding.TargetUpdated">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <!-- 透明度閃爍 -->
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1.0" To="0.3" Duration="0:0:0.2" AutoReverse="True"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </TextBlock.Triggers>
                                            </TextBlock>

                                        </Border>
                                        <TextBlock FontWeight="SemiBold" FontSize="14" DockPanel.Dock="Left">
                                            <Run Text="{Binding Symbol, Mode=OneWay}"/>
                                            <Run Text=" - "/>
                                            <Run Text="{Binding Name, Mode=OneWay}"/>
                                        </TextBlock>

                                    </DockPanel>

                                    <TextBlock DockPanel.Dock="Top">
                                        <Run Text="訊號: "/>
                                        <Run Text="{Binding Signal, Mode=OneWay}"/>
                                    </TextBlock>

                                    <TextBlock Margin="0,0,0,6">
                                        <Run Text="最新價格: "/>
                                        <Run Text="{Binding LatestPrice, StringFormat=F2, Mode=OneWay}"/>
                                        <Run Text=" 漲跌幅: "/>
                                        <Run Text="{Binding ChangePercent, StringFormat=F2, Mode=OneWay}"/>
                                        <Run Text="%   MA5: "/>
                                        <Run Text="{Binding MA5, StringFormat=F2, Mode=OneWay}"/>
                                        <Run Text="   MA20: "/>
                                        <Run Text="{Binding MA20, StringFormat=F2, Mode=OneWay}"/>
                                    </TextBlock>

                                    <TextBlock Margin="0,0,0,4" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"
                                               Text="Y軸：價格(元)    X軸：時間(由左到右)"/>

                                    <Viewbox Stretch="Fill" Height="150" SizeChanged="ChartViewbox_OnSizeChanged"
                                             Width="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=ActualWidth}">
                                        <Canvas Width="{Binding ChartWidth}" Height="220" Background="{DynamicResource SurfaceAltBrush}" ClipToBounds="False"
                                                MouseMove="KLineCanvas_OnMouseMove" MouseLeave="KLineCanvas_OnMouseLeave"
                                                ToolTip="{Binding HoverInfo}">
                                            <ItemsControl ItemsSource="{Binding PriceLevels}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style TargetType="ContentPresenter">
                                                        <Setter Property="Canvas.Left" Value="0"/>
                                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                                    </Style>
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Canvas>
                                                            <Line X1="40" X2="{Binding DataContext.ChartWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Y1="0" Y2="0"
                                                                  Stroke="Gray" StrokeDashArray="2,3" StrokeThickness="0.8"/>
                                                            <TextBlock Text="{Binding Text}" FontSize="9" Foreground="{DynamicResource MutedForegroundBrush}" Margin="2,-10,0,0"/>
                                                        </Canvas>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <ItemsControl ItemsSource="{Binding Candles}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style TargetType="ContentPresenter">
                                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                                        <Setter Property="Canvas.Top" Value="0"/>
                                                    </Style>
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Canvas Width="8" Height="220">
                                                            <Line X1="4" X2="4" Y1="{Binding WickTop}" Y2="{Binding WickBottom}" Stroke="{DynamicResource AppForegroundBrush}" StrokeThickness="1"/>
                                                            <Rectangle Width="8" Height="{Binding BodyHeight}" Fill="{Binding BodyBrush}" Canvas.Top="{Binding BodyTop}"/>
                                                        </Canvas>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Polyline Points="{Binding Ma5Points}" Stroke="Orange" StrokeThickness="1.6"/>
                                            <Polyline Points="{Binding Ma20Points}" Stroke="DodgerBlue" StrokeThickness="1.6"/>
                                            <Line X1="0" X2="{Binding ChartWidth}" Y1="{Binding LatestPriceY}" Y2="{Binding LatestPriceY}"
                                                  Stroke="{DynamicResource AccentBrush}" StrokeThickness="1" StrokeDashArray="4,2"/>
                                            <Border Canvas.Left="6" Canvas.Top="{Binding LatestPriceY}" Padding="4,1"
                                                    Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1">
                                                <TextBlock Foreground="{DynamicResource AccentBrush}" FontSize="14">
                                                    <Run Text="Now: "/>
                                                    <Run Text="{Binding LatestPrice, StringFormat=F2, Mode=OneWay}"/>
                                                </TextBlock>
                                            </Border>
                                            <ItemsControl ItemsSource="{Binding SignalMarkers}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style TargetType="ContentPresenter">
                                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                                    </Style>
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Text}" Foreground="{Binding Brush}" FontWeight="Bold" FontSize="12"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <ItemsControl ItemsSource="{Binding TimeLabels}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style TargetType="ContentPresenter">
                                                        <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                                                        <Setter Property="Canvas.Top" Value="204"/>
                                                    </Style>
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Text}" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="9"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <ItemsControl ItemsSource="{Binding TimeLabels}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style TargetType="ContentPresenter">
                                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                                        <Setter Property="Canvas.Top" Value="0"/>
                                                    </Style>
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Line X1="0" X2="0" Y1="0" Y2="220" Stroke="{DynamicResource AppBorderBrush}" StrokeDashArray="2,3" StrokeThickness="0.8"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Line X1="{Binding CrosshairX}" X2="{Binding CrosshairX}" Y1="0" Y2="220"
                                                  Visibility="{Binding CrosshairVisibility}" Stroke="{DynamicResource AccentBrush}" StrokeThickness="1" StrokeDashArray="3,2"/>
                                            <Line X1="0" X2="{Binding ChartWidth}" Y1="{Binding CrosshairY}" Y2="{Binding CrosshairY}"
                                                  Visibility="{Binding CrosshairVisibility}" Stroke="{DynamicResource AccentBrush}" StrokeThickness="1" StrokeDashArray="3,2"/>
                                        </Canvas>
                                    </Viewbox>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                </DockPanel>

                <!-- 可拖曳分隔線 -->
                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                              Background="{DynamicResource AppBorderBrush}" Cursor="SizeWE"/>

                <!-- 三大法人排名面板 -->
                <Border Grid.Column="2" Margin="4,0,0,0" Padding="8"
                        BorderThickness="1" BorderBrush="{DynamicResource AppBorderBrush}" Background="{DynamicResource SurfaceAltBrush}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,6"
                                   Text="{Binding LatestRankingDate, StringFormat=三大法人買賣超排名（{0:yyyy/MM/dd}）}"/>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="歷史起始日：" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource MutedForegroundBrush}"/>
                            <DatePicker Width="116" Height="26" SelectedDate="{Binding TwseHistoryStartDate, Mode=TwoWay}"
                                        FontSize="12" VerticalContentAlignment="Center" Foreground="White"/>
                            <Button Content="{Binding UpdateTwseHistoryButtonText}" Width="70" Height="26" Margin="4,0,0,0"
                                    Command="{Binding UpdateTwseHistoryCommand}"
                                    IsEnabled="{Binding IsUpdatingTwseHistory, Converter={StaticResource InverseBoolConverter}}"/>
                        </StackPanel>
                        <Grid DockPanel.Dock="Top" Height="20" Margin="0,0,0,4">
                            <ProgressBar IsIndeterminate="True"
                                 Visibility="{Binding IsUpdatingTwseHistory, Converter={StaticResource BoolToVisibilityConverter}}"
                                 Foreground="{DynamicResource AccentBrush}"
                                 Background="Transparent" BorderThickness="0"/>
                            <TextBlock Text="{Binding UpdatingTwseText}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/>
                        </Grid>
                        <!-- 篩選 -->
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="篩選：" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource MutedForegroundBrush}"/>
                            <ComboBox Width="130" Height="24" FontSize="12"
                                      ItemsSource="{Binding RankingFilterOptions}"
                                      SelectedItem="{Binding RankingFilter, Mode=TwoWay}">
                            </ComboBox>
                            
                        </StackPanel>
                        <!-- 表頭 -->
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="72"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="#"    Foreground="{DynamicResource MutedForegroundBrush}"/>
                            <TextBlock Grid.Column="1" Text="代號"  Foreground="{DynamicResource MutedForegroundBrush}"/>
                            <TextBlock Grid.Column="2" Text="名稱"  Foreground="{DynamicResource MutedForegroundBrush}"/>
                            <TextBlock Grid.Column="3" Text="買賣超" Foreground="{DynamicResource MutedForegroundBrush}" TextAlignment="Right"/>
                            <TextBlock Grid.Column="4" Text="升降"  Foreground="{DynamicResource MutedForegroundBrush}" TextAlignment="Center"/>
                        </Grid>
                        <ListBox ItemsSource="{Binding FilteredTwseRankingItems}" BorderThickness="0" Background="{DynamicResource SurfaceAltBrush}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,1" ToolTip="{Binding TooltipText}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="48"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="72"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Rank}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Symbol}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="3" Text="{Binding ThreeMajorNet, StringFormat=N0}" TextAlignment="Right"/>
                                        <TextBlock Grid.Column="4" Text="{Binding RankDeltaText}" Foreground="{Binding RankDeltaBrush}" TextAlignment="Right" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
