<Window x:Class="StockTracker.StockDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="股票詳細資訊" Height="760" Width="980" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="12" Background="{DynamicResource AppBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="{DynamicResource SurfaceBrush}">
            <StackPanel Margin="8,8,20,8" >
                <TextBlock FontSize="16" FontWeight="SemiBold">
                    <Run Text=""/>
                    <Run Text="{Binding Symbol, Mode=OneWay}"/>
                    <Run Text=" - "/>
                    <Run Text="{Binding Name, Mode=OneWay}"/>
                </TextBlock>
                <TextBlock Margin="0,4,0,10">
                    <Run Text="MA5: "/>
                    <Run Text="{Binding MA5, StringFormat=F2, Mode=OneWay}"/>
                    <Run Text="   MA20: "/>
                    <Run Text="{Binding MA20, StringFormat=F2, Mode=OneWay}"/>
                    <Run Text="   MACD: "/>
                    <Run Text="{Binding MACD, StringFormat=F4, Mode=OneWay}"/>
                    <Run Text="   RSI: "/>
                    <Run Text="{Binding RSI, StringFormat=F2, Mode=OneWay}"/>
                    <Run Text="   訊號: "/>
                    <Run Text="{Binding Signal, Mode=OneWay}"/>
                </TextBlock>

                <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="8" Background="{DynamicResource SurfaceBrush}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,6">
                            <Run Text="K 線 + MA5 / MA20   收盤: "/>
                            <Run Text="{Binding LatestPrice, StringFormat=F2, Mode=OneWay}"/>
                            <Run Text="   MA5: "/>
                            <Run Text="{Binding MA5, StringFormat=F2, Mode=OneWay}"/>
                            <Run Text="   MA20: "/>
                            <Run Text="{Binding MA20, StringFormat=F2, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Margin="0,0,0,4" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"
                                   Text="Y軸：價格(元)    X軸：時間(由左到右)"/>
                        <Viewbox Stretch="Fill" Height="280" SizeChanged="ChartViewbox_OnSizeChanged"
                                 Width="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=ActualWidth}">
                            <Canvas Width="{Binding ChartWidth}" Margin="0,10,0,0"  Height="230" Background="{DynamicResource SurfaceAltBrush}" ClipToBounds="False"
                                MouseMove="KLineCanvas_OnMouseMove" MouseLeave="KLineCanvas_OnMouseLeave"
                                ToolTip="{Binding HoverInfo}">
                            <ItemsControl ItemsSource="{Binding PriceLevels}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="0"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Line X1="40" X2="{Binding DataContext.ChartWidth, RelativeSource={RelativeSource AncestorType=Canvas}}" Y1="0" Y2="0"
                                                  Stroke="Gray" StrokeDashArray="2,3" StrokeThickness="0.8"/>
                                            <TextBlock Text="{Binding Text}" FontSize="9" Foreground="{DynamicResource MutedForegroundBrush}" Margin="2,-10,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ItemsControl ItemsSource="{Binding Candles}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top" Value="0"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Canvas Width="8" Height="220">
                                            <Line X1="4" X2="4" Y1="{Binding WickTop}" Y2="{Binding WickBottom}" Stroke="{DynamicResource AppForegroundBrush}" StrokeThickness="1"/>
                                            <Rectangle Width="8" Height="{Binding BodyHeight}" Fill="{Binding BodyBrush}" Canvas.Top="{Binding BodyTop}"/>
                                        </Canvas>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Polyline Points="{Binding Ma5Points}" Stroke="Orange" StrokeThickness="1.6"/>
                            <Polyline Points="{Binding Ma20Points}" Stroke="DodgerBlue" StrokeThickness="1.6"/>
                            <Polyline Points="{Binding Ma120Points}" Stroke="Violet" StrokeThickness="1.4"/>
                                <Polyline Points="{Binding Ma240Points}" Stroke="#5E005E" StrokeThickness="1.4"/>
                            <Polyline Points="{Binding BollingerUpperPoints}" Stroke="#00E3E3" StrokeThickness="1" StrokeDashArray="4,2"/>
                            <Polyline Points="{Binding BollingerMiddlePoints}" Stroke="#60FFAA00" StrokeThickness="1" StrokeDashArray="2,2"/>
                            <Polyline Points="{Binding BollingerLowerPoints}" Stroke="#00E3E3" StrokeThickness="1" StrokeDashArray="4,2"/>
                            <Line X1="0" X2="{Binding ChartWidth}" Y1="{Binding LatestPriceY}" Y2="{Binding LatestPriceY}"
                                  Stroke="{DynamicResource AccentBrush}" StrokeThickness="1" StrokeDashArray="4,2"/>
                            <Border Canvas.Left="6" Canvas.Top="{Binding LatestPriceY}" Padding="4,1"
                                    Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1">
                                <TextBlock Foreground="{DynamicResource AccentBrush}" FontSize="12">
                                    <Run Text="即時價: "/>
                                    <Run Text="{Binding LatestPrice, StringFormat=F2, Mode=OneWay}"/>
                                </TextBlock>
                            </Border>

                            <ItemsControl ItemsSource="{Binding SignalMarkers}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Text}" Foreground="{Binding Brush}" FontWeight="Bold" FontSize="12"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ItemsControl ItemsSource="{Binding TimeLabels}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                                        <Setter Property="Canvas.Top" Value="204"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Text}" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="9"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ItemsControl ItemsSource="{Binding TimeLabels}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top" Value="0"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Line X1="0" X2="0" Y1="0" Y2="220" Stroke="{DynamicResource AppBorderBrush}" StrokeDashArray="2,3" StrokeThickness="0.8"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Line X1="{Binding CrosshairX}" X2="{Binding CrosshairX}" Y1="0" Y2="220"
                                  Visibility="{Binding CrosshairVisibility}" Stroke="{DynamicResource AccentBrush}" StrokeThickness="1" StrokeDashArray="3,2"/>
                            <Line X1="0" X2="{Binding ChartWidth}" Y1="{Binding CrosshairY}" Y2="{Binding CrosshairY}"
                                  Visibility="{Binding CrosshairVisibility}" Stroke="{DynamicResource AccentBrush}" StrokeThickness="1" StrokeDashArray="3,2"/>
                        </Canvas>
                        </Viewbox>
                    </StackPanel>
                </Border>

                <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="8" Background="{DynamicResource SurfaceBrush}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,6">
                            <Run Text="MACD   DIFF: "/>
                            <Run Text="{Binding MACD, StringFormat=F4, Mode=OneWay}"/>
                            <Run Text="   DEA: "/>
                            <Run Text="{Binding MacdSignal, StringFormat=F4, Mode=OneWay}"/>
                            <Run Text="   柱狀: "/>
                            <Run Text="{Binding MacdHistogramValue, StringFormat=F4, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Margin="0,0,0,4" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"
                                   Text="Y軸：MACD值    X軸：時間(由左到右)"/>
                        <Viewbox Stretch="Fill" Height="120"
                                 Width="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=ActualWidth}">
                        <Canvas Width="{Binding ChartWidth}" Height="120" Background="{DynamicResource SurfaceAltBrush}">
                            <Line X1="0" X2="{Binding ChartWidth}" Y1="{Binding MacdZeroY}" Y2="{Binding MacdZeroY}"
                                  Stroke="{DynamicResource MutedForegroundBrush}" StrokeThickness="1" StrokeDashArray="3,3"/>
                            <ItemsControl ItemsSource="{Binding MacdLevels}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="0"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Canvas>
                                            <Line X1="0" X2="{Binding DataContext.ChartWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Y1="0" Y2="0"
                                                  Stroke="{DynamicResource AppBorderBrush}" StrokeDashArray="2,3" StrokeThickness="0.8"/>
                                            <TextBlock Canvas.Left="{Binding DataContext.ChartWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                       Canvas.Top="{Binding LabelTop}"
                                                       Margin="4,0,0,0"
                                                       Text="{Binding Text}" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="9"/>
                                        </Canvas>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ItemsControl ItemsSource="{Binding MacdHistogram}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Rectangle Width="8" Height="{Binding Height}" Fill="{Binding Brush}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Polyline Points="{Binding MacdLinePoints}" Stroke="Purple" StrokeThickness="1.5"/>
                            <Polyline Points="{Binding SignalLinePoints}" Stroke="DarkOrange" StrokeThickness="1.5"/>
                            <TextBlock Canvas.Left="4" Canvas.Top="4" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="10" Text="+"/>
                            <TextBlock Canvas.Left="4" Canvas.Top="106" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="10" Text="-"/>
                        </Canvas>
                        </Viewbox>
                    </StackPanel>
                </Border>

                <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="8" Background="{DynamicResource SurfaceBrush}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,6">
                            <Run Text="RSI   目前值: "/>
                            <Run Text="{Binding RSI, StringFormat=F2, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Margin="0,0,0,4" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"
                                   Text="Y軸：RSI(0~100)    X軸：時間(由左到右)"/>
                        <Viewbox Stretch="Fill" Height="90"
                                 Width="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=ActualWidth}">
                        <Canvas Width="{Binding ChartWidth}" Height="90" Background="{DynamicResource SurfaceAltBrush}">
                            <ItemsControl ItemsSource="{Binding RsiLevels}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="0"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Canvas>
                                            <Line X1="0" X2="{Binding DataContext.ChartWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Y1="0" Y2="0"
                                                  Stroke="{DynamicResource AppBorderBrush}" StrokeDashArray="2,3" StrokeThickness="0.8"/>
                                            <TextBlock Canvas.Left="{Binding DataContext.ChartWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                       Canvas.Top="{Binding LabelTop}"
                                                       Margin="4,0,0,0"
                                                       Text="{Binding Text}" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="9"/>
                                        </Canvas>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Line X1="0" X2="{Binding ChartWidth}" Y1="27" Y2="27" Stroke="{DynamicResource MutedForegroundBrush}" StrokeDashArray="3,3"/>
                            <Line X1="0" X2="{Binding ChartWidth}" Y1="63" Y2="63" Stroke="{DynamicResource MutedForegroundBrush}" StrokeDashArray="3,3"/>
                            <Polyline Points="{Binding RsiLinePoints}" Stroke="Crimson" StrokeThickness="1.6"/>
                        </Canvas>
                        </Viewbox>
                    </StackPanel>
                </Border>

                <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="8" Background="{DynamicResource SurfaceBrush}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,6">
                            <Run Text="成交量   最新: "/>
                            <Run Text="{Binding LatestVolume, StringFormat=F0, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Margin="0,0,0,4" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"
                                   Text="Y軸：成交量    X軸：時間(由左到右)"/>
                        <Viewbox Stretch="Fill" Height="100"
                                 Width="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=ActualWidth}">
                        <Canvas Width="{Binding ChartWidth}" Height="100" Background="{DynamicResource SurfaceAltBrush}">
                            <ItemsControl ItemsSource="{Binding VolumeLevels}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="0"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Canvas>
                                            <Line X1="0" X2="{Binding DataContext.ChartWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Y1="0" Y2="0"
                                                  Stroke="{DynamicResource AppBorderBrush}" StrokeDashArray="2,3" StrokeThickness="0.8"/>
                                            <TextBlock Canvas.Left="{Binding DataContext.ChartWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                       Canvas.Top="{Binding LabelTop}"
                                                       Margin="4,0,0,0"
                                                       Text="{Binding Text}" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="9"/>
                                        </Canvas>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Line X1="0" X2="{Binding ChartWidth}" Y1="100" Y2="100"
                                  Stroke="{DynamicResource MutedForegroundBrush}" StrokeThickness="1"/>
                            <ItemsControl ItemsSource="{Binding VolumeBars}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Rectangle Width="8" Height="{Binding Height}" Fill="{Binding Brush}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Canvas.Left="4" Canvas.Top="86" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="10" Text="0"/>
                        </Canvas>
                        </Viewbox>
                    </StackPanel>
                </Border>

                <Border BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" Padding="8" Background="{DynamicResource SurfaceBrush}" Margin="0,0,0,10"
                        Visibility="{Binding ThreeMajorChartVisibility}">
                    <StackPanel>
                        <TextBlock Margin="0,0,0,6">
                            <Run Text="三大法人買賣超曲線"/>
                        </TextBlock>
                        <TextBlock Margin="0,0,0,4" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="11"
                                   Text="Y軸：買賣超股數    X軸：時間(由左到右)"/>
                        <Viewbox Stretch="Fill" Height="100"
                                 Width="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=ActualWidth}">
                            <Canvas Width="{Binding ChartWidth}" Height="110
                                    " Background="{DynamicResource SurfaceAltBrush}"
                                    MouseMove="ThreeMajorCanvas_OnMouseMove" MouseLeave="ThreeMajorCanvas_OnMouseLeave"
                                    ToolTip="{Binding ThreeMajorHoverInfo}">
                                <Line X1="0" X2="{Binding ChartWidth}" Y1="{Binding ThreeMajorZeroY}" Y2="{Binding ThreeMajorZeroY}"
                                      Stroke="{DynamicResource MutedForegroundBrush}" StrokeThickness="1" StrokeDashArray="3,3"/>
                                <ItemsControl ItemsSource="{Binding ThreeMajorLevels}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="0"/>
                                            <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Canvas>
                                                <Line X1="0" X2="{Binding DataContext.ChartWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Y1="0" Y2="0"
                                                      Stroke="Gray" StrokeDashArray="2,3" StrokeThickness="0.8"/>
                                                <TextBlock Canvas.Left="2" Canvas.Top="{Binding LabelTop}" Margin="0,0,0,0"
                                                           Text="{Binding Text}" Foreground="{DynamicResource MutedForegroundBrush}" FontSize="9"/>
                                            </Canvas>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Polyline Points="{Binding ForeignNetPoints}" Stroke="#FF66C2FF" StrokeThickness="1.8"/>
                                <Polyline Points="{Binding InvestmentTrustNetPoints}" Stroke="#FFFFC857" StrokeThickness="1.8"/>
                                <Polyline Points="{Binding DealerNetPoints}" Stroke="#FFFF7A7A" StrokeThickness="1.8"/>
                                <Line X1="{Binding ThreeMajorCrosshairX}" X2="{Binding ThreeMajorCrosshairX}" Y1="0" Y2="100"
                                      Visibility="{Binding ThreeMajorCrosshairVisibility}" Stroke="{DynamicResource AccentBrush}" StrokeThickness="1" StrokeDashArray="3,2"/>
                            </Canvas>
                        </Viewbox>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Foreground="#FF66C2FF" FontSize="11" Text="外資" Margin="0,0,12,0"/>
                            <TextBlock Foreground="#FFFFC857" FontSize="11" Text="投信" Margin="0,0,12,0"/>
                            <TextBlock Foreground="#FFFF7A7A" FontSize="11" Text="自營商"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Label Content="{Binding Signal, Mode=OneWay}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>

